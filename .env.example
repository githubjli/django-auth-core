DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0

# Development server
APP_HOST=127.0.0.1
APP_PORT=8001

# CORS settings
CORS_ALLOW_ALL_ORIGINS=True
