DEBUG=True
SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.0.24

# Prefer DATABASE_URL for Postgres, fallback to DB_* if not set.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/django_auth_core
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
