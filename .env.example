DEBUG=True
SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.0.24

# Prefer DATABASE_URL for Postgres, fallback to DB_* if not set.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/django_auth_core
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0

# Development server
APP_HOST=127.0.0.1
APP_PORT=8001

# CORS settings
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT settings
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

ANT_MEDIA_BASE_URL=https://media.meownews.online
ANT_MEDIA_APP_NAME=live
ANT_MEDIA_RTMP_BASE=rtmp://media.meownews.online/live
ANT_MEDIA_PLAYBACK_BASE=https://media.meownews.online/live/streams
ANT_MEDIA_PREVIEW_BASE=
